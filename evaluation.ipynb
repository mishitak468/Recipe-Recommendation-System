# %% [markdown]
# # Model Evaluation: Hybrid Recipe Recommender vs. Baseline
# This notebook evaluates the performance of the Hybrid Recommendation Engine against 
# a global "Top-Rated" baseline using Precision@k and NDCG.

# %%
import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from src.engine import RecipeEngine # Assuming your logic is encapsulated here
import matplotlib.pyplot as plt

# %% [markdown]
# ## 1. Data Preparation
# We load the interactions and recipes to create a held-out test set.
# A "relevant" item is defined as any recipe the user gave a 4 or 5 star rating.

# %%
interactions = pd.read_csv('../data/RAW_interactions.csv')
recipes = pd.read_csv('../data/RAW_recipes.csv')

# Filter for "relevant" interactions (Rating >= 4)
relevant_interactions = interactions[interactions['rating'] >= 4]

# Split into train and test
train_data, test_data = train_test_split(relevant_interactions, test_size=0.2, random_state=42)

# %% [markdown]
# ## 2. Baselines & Metrics Definitions

# %%
def precision_at_k(recommended_list, actual_list, k=10):
    relevant = [item for item in recommended_list[:k] if item in actual_list]
    return len(relevant) / k

def dcg_at_k(recommended_list, actual_list, k=10):
    relevance = [1 if item in actual_list else 0 for item in recommended_list[:k]]
    return np.sum([rel / np.log2(idx + 2) for idx, rel in enumerate(relevance)])

def ndcg_at_k(recommended_list, actual_list, k=10):
    actual_dcg = dcg_at_k(recommended_list, actual_list, k)
    # Ideal DCG: All relevant items are at the top
    ideal_list = [1] * min(len(actual_list), k) + [0] * max(0, k - len(actual_list))
    ideal_dcg = np.sum([rel / np.log2(idx + 2) for idx, rel in enumerate(ideal_list)])
    return actual_dcg / ideal_dcg if ideal_dcg > 0 else 0

# %% [markdown]
# ## 3. Running the Comparison
# We'll compare the **Top-Rated Popular** recipes vs. your **Hybrid Engine**.

# %%
# Baseline: Top 10 Recipes by Average Rating (min 50 reviews)
recipe_stats = interactions.groupby('recipe_id').agg({'rating': ['mean', 'count']})
recipe_stats.columns = ['avg_rating', 'review_count']
top_rated_baseline = recipe_stats[recipe_stats['review_count'] > 50].sort_values(by='avg_rating', ascending=False).head(10).index.tolist()

# Sample 100 users from test set for evaluation speed
sample_users = test_data['user_id'].unique()[:100]

results = []

for user_id in sample_users:
    actual_liked = test_data[test_data['user_id'] == user_id]['recipe_id'].tolist()
    
    # Hybrid Engine Recommendations (using your src/engine.py)
    # This assumes a method like get_recommendations(user_id, k=10)
    engine = RecipeEngine(train_data, recipes)
    hybrid_recs = engine.get_hybrid_recommendations(user_id, k=10)
    
    # Calculate Metrics
    results.append({
        'user_id': user_id,
        'baseline_p10': precision_at_k(top_rated_baseline, actual_liked, k=10),
        'hybrid_p10': precision_at_k(hybrid_recs, actual_liked, k=10),
        'baseline_ndcg': ndcg_at_k(top_rated_baseline, actual_liked, k=10),
        'hybrid_ndcg': ndcg_at_k(hybrid_recs, actual_liked, k=10)
    })

eval_df = pd.DataFrame(results)

# %% [markdown]
# ## 4. Final Results
# Here we compare the mean scores to validate the "35% improvement" claim.

# %%
summary = eval_df[['baseline_p10', 'hybrid_p10', 'baseline_ndcg', 'hybrid_ndcg']].mean()
improvement = (summary['hybrid_ndcg'] - summary['baseline_ndcg']) / summary['baseline_ndcg'] * 100

print(f"Mean Precision@10 (Baseline): {summary['baseline_p10']:.4f}")
print(f"Mean Precision@10 (Hybrid):   {summary['hybrid_p10']:.4f}")
print(f"Mean NDCG (Baseline):        {summary['baseline_ndcg']:.4f}")
print(f"Mean NDCG (Hybrid):          {summary['hybrid_ndcg']:.4f}")
print(f"\nTotal Improvement in Ranking (NDCG): {improvement:.2f}%")

# %%
# Visualizing the results
summary.plot(kind='bar', color=['skyblue', 'navy', 'lightgreen', 'darkgreen'])
plt.title('Performance Comparison: Baseline vs Hybrid')
plt.ylabel('Score')
plt.show()
